generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  TEACHER
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  TRUE_FALSE
  FILL_BLANK
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  questionBanks  QuestionBank[]
  exams          Exam[]
  students       Student[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  role         UserRole @default(TEACHER)
  name         String
  email        String
  passwordHash String   @map("password_hash")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  disabledAt         DateTime? @map("disabled_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exams  Exam[]

  @@unique([tenantId, email])
  @@map("users")
}

model QuestionBank {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("question_banks")
}

model Question {
  id         String       @id @default(uuid())
  bankId     String       @map("bank_id")
  type       QuestionType
  content    String
  options    Json?
  answer     String
  difficulty Int?         @default(1)
  tags       String[]
  deletedAt  DateTime?    @map("deleted_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  bank QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  examQuestions ExamQuestion[]

  @@map("questions")
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  FINISHED
}

model Exam {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  title       String
  description String?
  timeLimit   Int        @map("time_limit")
  passScore   Int        @map("pass_score")
  antiCheat   Boolean    @default(true) @map("anti_cheat")
  status      ExamStatus @default(DRAFT)
  createdBy   String     @map("created_by")
  deletedAt   DateTime?  @map("deleted_at")
  startTime   DateTime?  @map("start_time")
  endTime     DateTime?  @map("end_time")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator       User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  examQuestions ExamQuestion[]

  accessCode  String?    @map("access_code")

  examRecords ExamRecord[]

  @@map("exams")
}

model ExamQuestion {
  examId     String @map("exam_id")
  questionId String @map("question_id")
  score      Int    @default(1)
  sortOrder  Int    @default(0) @map("sort_order")

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
  @@map("exam_questions")
}

enum RecordStatus {
  IN_PROGRESS
  SUBMITTED
  CANCELLED
}

model Student {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  studentNo String    @map("student_no")
  class     String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  examRecords ExamRecord[]

  @@unique([tenantId, studentNo])
  @@map("students")
}

model ExamRecord {
  id        String       @id @default(uuid())
  examId    String       @map("exam_id")
  studentId String       @map("student_id")
  startTime DateTime?    @map("start_time")
  endTime   DateTime?    @map("end_time")
  score     Int?
  status    RecordStatus @default(IN_PROGRESS)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("exam_records")
}

model Answer {
  recordId       String  @map("record_id")
  questionId     String  @map("question_id")
  selectedAnswer String? @map("selected_answer")
  correct        Boolean @default(false)
  timeSpent      Int?    @map("time_spent")

  record ExamRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@id([recordId, questionId])
  @@map("answers")
}
