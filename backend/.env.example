# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exam_saas?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-string
REFRESH_SECRET=change-me-to-another-random-string

# Sentry (注册地址: https://sentry.io)
SENTRY_DSN=

# Seed (首次部署创建管理员)
SEED_ADMIN_EMAIL=admin@exam-saas.local
SEED_ADMIN_PASSWORD=Admin123456
